{
  "fonts": [
    {
      "family": "Fredoka",
      "weight": 400,
      "style": "normal"
    },
    {
      "family": "Fredoka",
      "weight": 500,
      "style": "normal"
    },
    {
      "family": "Fredoka",
      "weight": 600,
      "style": "normal"
    },
    {
      "family": "Figtree",
      "weight": 400,
      "style": "normal"
    },
    {
      "family": "Figtree",
      "weight": 500,
      "style": "normal"
    },
    {
      "family": "Figtree",
      "weight": 600,
      "style": "normal"
    },
    {
      "family": "Figtree",
      "weight": 700,
      "style": "normal"
    }
  ],
  "systemColors": {
    "base": "#ffffff",
    "base-muted": "#FFF4F5",
    "base-alt": "#050C11",
    "panel": "#ffffff",
    "fg": "#050C11",
    "fg-muted": "#707070",
    "fg-alt": "#EDECEC",
    "brand": "#DB6885",
    "on-brand": "#ffffff",
    "border": "#EDECEC"
  },
  "customColors": [
    {
      "id": "yellow",
      "name": "yellow",
      "value": "#FFC107"
    },
    {
      "id": "pink-light",
      "name": "pink-light",
      "value": "#FFD3D7"
    }
  ],
  "palette": {
    "primary": {
      "label": "pink",
      "colors": [
        "#FFF4F5",
        "#FFD3D7",
        "#DB6885",
        "#AE1339",
        "#7A0D28"
      ]
    },
    "grays": {
      "label": "neutral",
      "colors": [
        "#ffffff",
        "#EDECEC",
        "#707070",
        "#2F3137",
        "#050C11"
      ]
    }
  },
  "headingTypography": {
    "heading-xl": {
      "fontFamily": "Figtree",
      "fontWeight": 700,
      "fontSize": 70,
      "lineHeight": 84,
      "letterSpacing": -2.8,
      "mobileFontSize": 38,
      "mobileLineHeight": 46
    },
    "heading-lg": {
      "fontFamily": "Figtree",
      "fontWeight": 700,
      "fontSize": 54,
      "lineHeight": 81,
      "letterSpacing": -2.16,
      "mobileFontSize": 28,
      "mobileLineHeight": 42
    },
    "heading-md": {
      "fontFamily": "Fredoka",
      "fontWeight": 600,
      "fontSize": 28,
      "lineHeight": 42,
      "letterSpacing": -0.56,
      "mobileFontSize": 20,
      "mobileLineHeight": 30
    },
    "heading-sm": {
      "fontFamily": "Figtree",
      "fontWeight": 700,
      "fontSize": 24,
      "lineHeight": 36,
      "letterSpacing": -0.96,
      "mobileFontSize": 24,
      "mobileLineHeight": 36
    },
    "heading-xs": {
      "fontFamily": "Figtree",
      "fontWeight": 600,
      "fontSize": 22,
      "lineHeight": 33,
      "letterSpacing": -0.88,
      "mobileFontSize": 22,
      "mobileLineHeight": 33
    }
  },
  "bodyTypography": {
    "body-lg": {
      "fontFamily": "Figtree",
      "fontWeight": 400,
      "fontSize": 18,
      "lineHeight": 32,
      "letterSpacing": -0.72
    },
    "body-md": {
      "fontFamily": "Figtree",
      "fontWeight": 400,
      "fontSize": 16,
      "lineHeight": 32,
      "letterSpacing": -0.64
    },
    "body-sm": {
      "fontFamily": "Figtree",
      "fontWeight": 500,
      "fontSize": 14,
      "lineHeight": 14,
      "letterSpacing": -0.56
    }
  },
  "prose": {
    "elements": {
      "h1": {
        "typographyClass": "heading-xl",
        "marginBottom": 1.5
      },
      "h2": {
        "typographyClass": "heading-lg",
        "marginBottom": 1.25
      },
      "h3": {
        "typographyClass": "heading-md",
        "marginBottom": 1
      },
      "p": {
        "typographyClass": "body-md",
        "marginBottom": 1.25
      },
      "li": {
        "typographyClass": "body-md"
      }
    },
    "lists": {
      "listStyleType": "disc",
      "indent": 1.5,
      "itemSpacing": 0.5
    },
    "links": {
      "color": "brand",
      "hoverColor": "fg",
      "underline": "always"
    }
  },
  "buttons": {
    "global": {
      "fontFamily": "Figtree",
      "fontWeight": 500,
      "uppercase": false,
      "sizes": {
        "lg": {
          "fontSize": 16,
          "letterSpacing": -0.64,
          "opticalYOffset": 0,
          "paddingTop": 14,
          "paddingBottom": 14,
          "paddingLeft": 32,
          "paddingRight": 32,
          "borderRadius": 32
        },
        "md": {
          "fontSize": 16,
          "letterSpacing": -0.64,
          "opticalYOffset": 0,
          "paddingTop": 10,
          "paddingBottom": 10,
          "paddingLeft": 24,
          "paddingRight": 24,
          "borderRadius": 32
        },
        "sm": {
          "fontSize": 14,
          "letterSpacing": -0.56,
          "opticalYOffset": 0,
          "paddingTop": 8,
          "paddingBottom": 8,
          "paddingLeft": 20,
          "paddingRight": 20,
          "borderRadius": 32
        }
      }
    },
    "variants": {
      "primary": {
        "backgroundColor": "system:brand",
        "textColor": "system:on-brand",
        "borderColor": "transparent",
        "borderWidth": 0,
        "hoverPreset": "darken"
      },
      "secondary": {
        "backgroundColor": "system:base-muted",
        "textColor": "system:fg",
        "borderColor": "transparent",
        "borderWidth": 0,
        "hoverPreset": "darken"
      },
      "outline": {
        "backgroundColor": "transparent",
        "textColor": "system:brand",
        "borderColor": "system:brand",
        "borderWidth": 1,
        "hoverPreset": "fill"
      },
      "ghost": {
        "backgroundColor": "transparent",
        "textColor": "system:fg",
        "borderColor": "transparent",
        "borderWidth": 0,
        "hoverPreset": "lighten"
      }
    }
  }
}
