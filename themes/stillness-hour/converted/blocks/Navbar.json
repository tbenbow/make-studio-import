{
  "description": "Sticky nav with logo",
  "fields": [
    {
      "type": "image",
      "name": "Logo"
    },
    {
      "type": "text",
      "name": "Logo Text",
      "default": "The Stillness Hour"
    },
    {
      "type": "text",
      "name": "Logo Link",
      "default": "/"
    },
    {
      "type": "items",
      "name": "Links",
      "default": [
        {
          "label": "Episodes",
          "url": "#episodes"
        },
        {
          "label": "About",
          "url": "#about"
        },
        {
          "label": "Listen",
          "url": "#listen"
        }
      ],
      "config": {
        "fields": [
          {
            "type": "text",
            "name": "Label"
          },
          {
            "type": "text",
            "name": "Url"
          }
        ]
      }
    },
    {
      "type": "text",
      "name": "Button Label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "name": "Button Link",
      "default": "#subscribe"
    }
  ]
}
