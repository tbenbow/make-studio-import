{
  "makeStudioFields": true,
  "version": 1,
  "description": "Blog post body with rich text and back link",
  "fields": [
    {
      "type": "wysiwyg",
      "name": "Body",
      "default": "<p>Start writing your post here...</p>"
    },
    {
      "type": "text",
      "name": "Back Label",
      "default": "\u2190 Back to Home"
    },
    {
      "type": "text",
      "name": "Back Link",
      "default": "/"
    }
  ]
}
