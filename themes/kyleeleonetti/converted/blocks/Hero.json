{
  "makeStudioFields": true,
  "version": 1,
  "description": "Full-width centered hero with heading, subheadline, intro, CTAs, and image",
  "fields": [
    {
      "type": "text",
      "name": "Headline",
      "default": "Kylee Leonetti"
    },
    {
      "type": "text",
      "name": "Subheadline",
      "default": "Welcome To My Online Writing Sanctuary"
    },
    {
      "type": "wysiwyg",
      "name": "Intro",
      "default": "<p>Have a seat right here next to me, on the chair if the floor is bad for your knees. Let\u2019s talk about everything, plans, ideas and dreams, firm-to-shaky faiths and hard realities; this is the stuff that makes us human, after all.</p>"
    },
    {
      "type": "items",
      "name": "Buttons",
      "default": [
        { "label": "About Me", "link": "/about", "style": "primary" },
        { "label": "Explore My Writing", "link": "/writing", "style": "outline" }
      ],
      "config": {
        "fields": [
          { "type": "text", "name": "Label" },
          { "type": "text", "name": "Link" },
          {
            "type": "select",
            "name": "Style",
            "config": {
              "selectOptions": [
                { "key": "Primary", "value": "primary" },
                { "key": "Secondary", "value": "secondary" },
                { "key": "Outline", "value": "outline" },
                { "key": "Ghost", "value": "ghost" }
              ]
            }
          }
        ]
      }
    },
    { "type": "image", "name": "Image" },
    { "type": "text", "name": "Image Alt", "default": "" }
  ]
}
