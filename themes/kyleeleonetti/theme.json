  "headingTypography": {
    "heading-xl": {
      "fontFamily": "Cormorant Garamond",
      "fontWeight": 400,
      "fontStyle": "italic",
      "fontSize": 56,
      "lineHeight": 64,
      "letterSpacing": -0.5,
