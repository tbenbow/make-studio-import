      "letterSpacing": -0.3,
      "mobileFontSize": 28,
      "mobileLineHeight": 34
    },
    "heading-md": {
      "fontFamily": "Cormorant Garamond",
      "fontWeight": 400,
      "fontSize": 28,
      "lineHeight": 36,
      "letterSpacing": -0.2,
      "mobileFontSize": 22,
      "mobileLineHeight": 28
    },
    "heading-sm": {
      "fontFamily": "Nunito Sans",
      "fontWeight": 700,
      "fontSize": 20,
