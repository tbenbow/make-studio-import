      "fontSize": 18,
      "lineHeight": 30,
      "letterSpacing": 0
    },
    "body-md": {
      "fontFamily": "Nunito Sans",
      "fontWeight": 400,
      "fontSize": 16,
      "lineHeight": 28,
      "letterSpacing": 0
