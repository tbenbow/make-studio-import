{
  "fonts": [
    {
      "family": "Rajdhani",
      "weight": 500,
      "style": "normal"
    },
    {
      "family": "Rajdhani",
      "weight": 600,
      "style": "normal"
    },
    {
      "family": "Rajdhani",
      "weight": 700,
      "style": "normal"
    },
    {
      "family": "Inter",
      "weight": 400,
      "style": "normal"
    },
    {
      "family": "Inter",
      "weight": 500,
      "style": "normal"
    },
    {
      "family": "Inter",
      "weight": 600,
      "style": "normal"
    },
    {
      "family": "Inter",
      "weight": 700,
      "style": "normal"
    }
  ],
  "systemColors": {
    "base": "#ffffff",
    "base-muted": "#f5f5f5",
    "base-alt": "#1a1a1a",
    "panel": "#ffffff",
    "fg": "#2d2d2d",
    "fg-muted": "#737373",
    "fg-alt": "#a3a3a3",
    "brand": "#d42027",
    "on-brand": "#ffffff",
    "border": "#e5e5e5"
  },
  "customColors": [
    {
      "id": "charcoal-dark",
      "name": "charcoal-dark",
      "value": "#1a1a1a"
    }
  ],
  "palette": {
    "primary": {
      "label": "primary",
      "colors": [
        "#fecaca",
        "#f87171",
        "#d42027",
        "#b81b21",
        "#7f1d1d"
      ]
    },
    "grays": {
      "label": "gray",
      "colors": [
        "#f5f5f5",
        "#d4d4d4",
        "#737373",
        "#3a3a3a",
        "#1a1a1a"
      ]
    }
  },
  "headingTypography": {
    "heading-xl": {
      "fontFamily": "Rajdhani",
      "fontWeight": 700,
      "fontSize": 72,
      "lineHeight": 76,
      "letterSpacing": -1,
      "mobileFontSize": 48,
      "mobileLineHeight": 50
    },
    "heading-lg": {
      "fontFamily": "Rajdhani",
      "fontWeight": 700,
      "fontSize": 48,
      "lineHeight": 52,
      "letterSpacing": -0.5,
      "mobileFontSize": 36,
      "mobileLineHeight": 40
    },
    "heading-md": {
      "fontFamily": "Rajdhani",
      "fontWeight": 700,
      "fontSize": 36,
      "lineHeight": 40,
      "letterSpacing": 0,
      "mobileFontSize": 28,
      "mobileLineHeight": 32
    },
    "heading-sm": {
      "fontFamily": "Rajdhani",
      "fontWeight": 700,
      "fontSize": 20,
      "lineHeight": 28,
      "letterSpacing": 0,
      "mobileFontSize": 18,
      "mobileLineHeight": 24
    },
    "heading-xs": {
      "fontFamily": "Rajdhani",
      "fontWeight": 600,
      "fontSize": 16,
      "lineHeight": 24,
      "letterSpacing": 0,
      "mobileFontSize": 14,
      "mobileLineHeight": 20
    }
  },
  "bodyTypography": {
    "body-lg": {
      "fontFamily": "Inter",
      "fontWeight": 400,
      "fontSize": 18,
      "lineHeight": 28,
      "letterSpacing": 0
    },
    "body-md": {
      "fontFamily": "Inter",
      "fontWeight": 400,
      "fontSize": 16,
      "lineHeight": 26,
      "letterSpacing": 0
    },
    "body-sm": {
      "fontFamily": "Inter",
      "fontWeight": 500,
      "fontSize": 14,
      "lineHeight": 22,
      "letterSpacing": 0
    }
  },
  "prose": {
    "elements": {
      "h1": {
        "typographyClass": "heading-xl",
        "marginBottom": 1.5
      },
      "h2": {
        "typographyClass": "heading-lg",
        "marginBottom": 1.25
      },
      "h3": {
        "typographyClass": "heading-md",
        "marginBottom": 1
      },
      "h4": {
        "typographyClass": "heading-sm",
        "marginBottom": 0.75
      },
      "h5": {
        "typographyClass": "heading-xs",
        "marginBottom": 0.5
      },
      "h6": {
        "typographyClass": "heading-xs",
        "marginBottom": 0.5
      },
      "p": {
        "typographyClass": "body-md",
        "marginBottom": 1.25
      },
      "ul": {
        "typographyClass": "body-md",
        "marginBottom": 1.25
      },
      "ol": {
        "typographyClass": "body-md",
        "marginBottom": 1.25
      }
    },
    "lists": {
      "listStyleType": "disc",
      "indent": 1.5,
      "itemSpacing": 0.5,
      "nestedIndent": 1.5
    },
    "links": {
      "color": "brand",
      "hoverColor": "brand",
      "underline": "always"
    }
  },
  "buttons": {
    "global": {
      "fontFamily": "Inter",
      "fontWeight": 600,
      "uppercase": false,
      "sizes": {
        "lg": {
          "fontSize": 18,
          "letterSpacing": 0,
          "opticalYOffset": 0,
          "paddingTop": 16,
          "paddingBottom": 16,
          "paddingLeft": 32,
          "paddingRight": 32,
          "borderRadius": 4
        },
        "md": {
          "fontSize": 14,
          "letterSpacing": 0,
          "opticalYOffset": 0,
          "paddingTop": 10,
          "paddingBottom": 10,
          "paddingLeft": 20,
          "paddingRight": 20,
          "borderRadius": 4
        },
        "sm": {
          "fontSize": 14,
          "letterSpacing": 0,
          "opticalYOffset": 0,
          "paddingTop": 6,
          "paddingBottom": 6,
          "paddingLeft": 14,
          "paddingRight": 14,
          "borderRadius": 4
        }
      }
    },
    "variants": {
      "primary": {
        "backgroundColor": "system:brand",
        "textColor": "system:on-brand",
        "borderColor": "transparent",
        "borderWidth": 0,
        "hoverPreset": "darken"
      },
      "secondary": {
        "backgroundColor": "system:base-muted",
        "textColor": "system:fg",
        "borderColor": "transparent",
        "borderWidth": 0,
        "hoverPreset": "darken"
      },
      "outline": {
        "backgroundColor": "transparent",
        "textColor": "system:fg",
        "borderColor": "system:border",
        "borderWidth": 1,
        "hoverPreset": "fill"
      },
      "ghost": {
        "backgroundColor": "transparent",
        "textColor": "system:fg-muted",
        "borderColor": "transparent",
        "borderWidth": 0,
        "hoverPreset": "lighten"
      }
    }
  }
}
