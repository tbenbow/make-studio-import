      "config": {
        "fields": [
          { "type": "text", "name": "Label" },
          { "type": "link", "name": "Link" },
          { "type": "select", "name": "Style", "config": { "dataStoreId": "698be9a2db8e5c335edc75e1" } },
          { "type": "select", "name": "Size", "config": { "dataStoreId": "698c898950a2e6bef85751ae" } }
        ]
      }
    }
