    },
    "Hero": {
      "Eyebrow": "Opera Singer — Voice Over — Live Events",
      "Headline": "A voice you don't forget",
      "Subheadline": "<p>Allen Ginsberg is a classically trained bass-baritone who brings fifteen years of vocal mastery to every stage, studio, and screen. Deep. Resonant. Unforgettable.</p>",
      "Photo": "$hero",
      "Buttons": [
        { "label": "Hear My Work", "link": "#services", "style": "primary" },
        { "label": "Book Now", "link": "/contact", "style": "outline" }
      ],
      "align": "items-start text-left"
    },
    "Features Alternating": {
      "Eyebrow": "Services",
      "Headline": "What Allen does",
      "Subheadline": "<p>Three disciplines, one voice. Classically trained and professionally versatile.</p>",
      "Features": [
        {
          "title": "Opera & Concert Performance",
          "description": "Full opera productions, orchestral concerts, oratorio, and solo recitals. Allen's bass-baritone repertoire spans from Mozart and Verdi to contemporary works. Available for productions, guest soloist engagements, and concert series nationwide.",
          "image": "$featureOpera",
          "button_label": "Learn More",
          "button_link": "/opera"
        },
        {
          "title": "Professional Voice Over",
          "description": "A deep, resonant voice for commercial spots, documentary narration, audiobooks, corporate video, and brand campaigns. Allen records from a professional home studio with broadcast-quality equipment — available for remote sessions and in-studio bookings.",
          "image": "$featureVoiceover",
          "button_label": "Hear Samples",
          "button_link": "/samples"
        },
        {
          "title": "Live Event Hosting",
          "description": "Commanding stage presence for corporate galas, award ceremonies, fundraisers, product launches, and special events. Allen brings the gravitas of a trained performer and the warmth of a natural host to every occasion.",
          "image": "$featureEvents",
          "button_label": "Book an Event",
          "button_link": "/contact"
        }
      ]
    },
    "Content": {
      "Headline": "Trained for the stage. Ready for anything.",
      "Category": "About Allen",
      "Subheadline": "Fifteen years of filling rooms.",
      "Content": "<p>Allen Ginsberg earned his Master of Music in Vocal Performance and spent the first decade of his career on opera stages — performing with companies and orchestras across the country. His bass-baritone voice, praised for its depth and emotional range, earned him roles in everything from baroque oratorio to contemporary opera premieres.</p><p>Today, Allen brings that same training and instinct to commercial voice over and live event work. His clients include production companies, advertising agencies, corporate event planners, and nonprofit organizations who need a voice that commands attention without demanding it.</p>",
      "align": "items-center text-center"
    },
    "Testimonial": {
      "Quote": "<p>We auditioned over forty voice actors for our documentary series. Allen was the clear choice — his voice has this rare combination of authority and warmth that made every word land. He elevated the entire project.</p>",
      "Image": "$testimonialImage",
      "Name": "David Moreira",
      "Byline": "Executive Producer, Greyline Films"
    },
    "Stats": {
      "Eyebrow": "Track Record",
      "Headline": "The numbers behind the voice",
      "Subheadline": "<p>A career built on consistency, craft, and repeat bookings.</p>",
      "Stats": [
        { "stat": "15+", "text": "Years of professional performance" },
        { "stat": "200+", "text": "Live events and productions" },
        { "stat": "50+", "text": "Voice over projects completed" },
        { "stat": "98%", "text": "Client rebooking rate" }
      ]
    },
    "CTA Highlight": {
      "Eyebrow": "Ready?",
      "Headline": "Let's put that voice to work",
      "Subheadline": "<p>Whether it's a 30-second spot or a three-hour gala, Allen brings the same preparation and presence to every engagement. Tell him about your project.</p>",
      "Button Label": "Hire Allen",
      "Button Link": "/contact",
      "Secondary Button Label": "Listen to Samples",
      "Secondary Button Link": "/samples",
      "Demo Image": "$ctaDemo",
      "Footer": "<p>Typically responds within 24 hours. Based in the Twin Cities, available nationwide.</p>"
    },
    "FooterNewsletter": {
      "Newsletter Headline": "Updates from Allen",
      "Newsletter Text": "<p>New recordings, upcoming performances, and availability — straight to your inbox.</p>",
