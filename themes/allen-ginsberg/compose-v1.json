      "Primary Button Label": "Hear My Work",
      "Primary Button URL": "#services",
      "Secondary Button Label": "Book Now",
      "Secondary Button URL": "/contact",
      "Image": "$split"
    },
    "Features Triple": {
      "Eyebrow": "Services",
      "Headline": "Three ways to work with Allen",
      "Subheadline": "<p>From the opera house to the recording booth to the live stage — a voice trained for any occasion.</p>",
      "Features": [
        {
          "title": "Opera & Concert",
          "description": "Professionally trained bass-baritone available for opera productions, concert series, oratorio, and recital performances. Repertoire spans from Mozart to contemporary works.",
          "image": "$featureOpera"
        },
        {
          "title": "Voice Over",
          "description": "A deep, resonant voice for commercial spots, narration, audiobooks, documentaries, and corporate video. Professional home studio with broadcast-quality recording.",
          "image": "$featureVoiceover"
        },
        {
          "title": "Live Events",
          "description": "Commanding presence for corporate galas, award ceremonies, fundraisers, and special events. Allen brings gravitas and warmth as an emcee and live host.",
          "image": "$featureEvents"
        }
      ]
    },
    "LTA": {
      "Headline": "Trained for the stage, built for any medium",
      "Subheadline": "About Allen",
      "Text": "Allen Ginsberg is a classically trained opera singer whose deep, resonant bass-baritone voice has filled concert halls, recording studios, and live event stages for over fifteen years. After earning his Master of Music in Vocal Performance, Allen built a career spanning opera companies, symphony orchestras, and recital series across the country.\n\nToday, Allen brings that same vocal discipline and dramatic instinct to voice over work and live event hosting — offering clients a rare combination of technical precision, emotional depth, and effortless stage presence.",
      "Button Label": "Get in Touch",
      "Image": "$lta",
      "Highlights": [
        { "title": "15+ Years", "label": "Experience", "description": "Professional vocal performance across opera, concert, and commercial work." },
        { "title": "Master of Music", "label": "Education", "description": "Advanced degree in Vocal Performance from a top conservatory program." },
        { "title": "200+ Events", "label": "Track Record", "description": "Opera productions, corporate galas, commercial recordings, and live broadcasts." }
      ]
    },
    "Testimonial Large": {
      "Quote": "<p>Allen's voice stopped the entire room. We hired him to emcee our annual gala and he elevated the entire evening — from his opening remarks to the way he carried the audience through every segment. Half our guests asked for his card afterward.</p>",
      "Name": "Rebecca Thornton",
      "Byline": "Director of Events, Lakewood Foundation",
      "Photo": "$testimonialPhoto"
    },
    "Stats": {
      "Eyebrow": "By the Numbers",
      "Headline": "A career measured in standing ovations",
      "Subheadline": "<p>Fifteen years of filling rooms with a voice that resonates long after the last note.</p>",
      "Stats": [
        { "stat": "15+", "text": "Years performing professionally" },
        { "stat": "200+", "text": "Live performances and events" },
        { "stat": "50+", "text": "Voice over projects delivered" },
        { "stat": "30+", "text": "Opera and concert productions" }
      ]
    },
    "CTA": {
      "Eyebrow": "Work With Allen",
      "Headline": "Let's make something unforgettable",
      "Subheadline": "<p>Whether you need a voice for your next campaign, a host for your gala, or a singer for your production — Allen is ready. Reach out to discuss your project.</p>",
      "Buttons": [
        { "label": "Book Allen", "link": "/contact", "style": "primary" },
        { "label": "Listen to Samples", "link": "/samples", "style": "ghost" }
      ],
      "Align": "items-center text-center"
    },
