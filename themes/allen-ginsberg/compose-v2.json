      "Eyebrow": "Ready to Work Together?",
      "Headline": "Your project deserves a voice that resonates",
      "Subheadline": "<p>From opera stages to recording studios to live events — Allen brings fifteen years of vocal mastery to every engagement. Let's talk about yours.</p>",
      "Buttons": [
        { "label": "Book Allen", "link": "/contact", "style": "primary" },
        { "label": "Listen to Samples", "link": "/samples", "style": "ghost" }
      ],
      "Align": "items-center text-center"
    },
