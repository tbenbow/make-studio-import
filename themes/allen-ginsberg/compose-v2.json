      "fg": "#1a1a1a",
      "fg-muted": "#5c5c5c",
      "fg-alt": "#8c8c8c"
    },
    "palette": {
      "primary": { "label": "primary", "colors": ["rgb(220,230,240)", "rgb(160,185,210)", "rgb(80,120,160)", "rgb(44,62,80)", "rgb(30,42,55)"] },
      "accent1": { "label": "accent-1", "colors": ["rgb(250,240,230)", "rgb(230,210,180)", "rgb(200,170,130)", "rgb(170,130,80)", "rgb(130,95,50)"] },
      "accent2": { "label": "accent-2", "colors": ["rgb(235,230,225)", "rgb(200,190,180)", "rgb(160,145,130)", "rgb(120,105,90)", "rgb(85,75,65)"] },
      "accent3": { "label": "accent-3", "colors": ["rgb(230,225,235)", "rgb(190,180,200)", "rgb(140,125,160)", "rgb(100,80,120)", "rgb(70,55,85)"] },
      "grays": { "label": "gray", "colors": ["rgb(250,248,245)", "rgb(200,195,190)", "rgb(140,140,140)", "rgb(92,92,92)", "rgb(26,26,26)"] }
    },
    "headingTypography": {
      "heading-xl": { "fontFamily": "Playfair Display", "fontWeight": 700, "fontSize": 56, "lineHeight": 64, "letterSpacing": -1, "mobileFontSize": 36, "mobileLineHeight": 42 },
      "heading-lg": { "fontFamily": "Playfair Display", "fontWeight": 700, "fontSize": 44, "lineHeight": 52, "letterSpacing": -0.8, "mobileFontSize": 28, "mobileLineHeight": 34 },
      "heading-md": { "fontFamily": "Playfair Display", "fontWeight": 700, "fontSize": 30, "lineHeight": 38, "letterSpacing": -0.5, "mobileFontSize": 22, "mobileLineHeight": 28 },
      "heading-sm": { "fontFamily": "Source Sans 3", "fontWeight": 600, "fontSize": 22, "lineHeight": 30, "letterSpacing": -0.2, "mobileFontSize": 18, "mobileLineHeight": 24 },
      "heading-xs": { "fontFamily": "Source Sans 3", "fontWeight": 600, "fontSize": 18, "lineHeight": 25, "letterSpacing": -0.1, "mobileFontSize": 16, "mobileLineHeight": 22 }
    },
    "bodyTypography": {
      "body-lg": { "fontFamily": "Source Sans 3", "fontWeight": 400, "fontSize": 18, "lineHeight": 32, "letterSpacing": 0 },
      "body-md": { "fontFamily": "Source Sans 3", "fontWeight": 400, "fontSize": 16, "lineHeight": 28, "letterSpacing": 0 },
      "body-sm": { "fontFamily": "Source Sans 3", "fontWeight": 400, "fontSize": 14, "lineHeight": 22, "letterSpacing": 0 }
    },
    "prose": {
      "elements": {
        "h1": { "typographyClass": "heading-xl", "marginBottom": 1.5 },
        "h2": { "typographyClass": "heading-lg", "marginBottom": 1.25 },
        "h3": { "typographyClass": "heading-md", "marginBottom": 1 },
        "h4": { "typographyClass": "heading-sm", "marginBottom": 0.75 },
        "h5": { "typographyClass": "heading-xs", "marginBottom": 0.5 },
        "h6": { "typographyClass": "heading-xs", "marginBottom": 0.5 },
        "p": { "typographyClass": "body-md", "marginBottom": 1.25 },
        "ul": { "typographyClass": "body-md", "marginBottom": 1.25 },
        "ol": { "typographyClass": "body-md", "marginBottom": 1.25 }
      },
      "lists": { "listStyleType": "disc", "indent": 1.5, "itemSpacing": 0.5, "nestedIndent": 1.5 },
      "links": { "color": "accent", "hoverColor": "primary", "underline": "always" },
      "customCSS": ""
    },
    "buttons": {
      "global": {
        "fontFamily": "'Source Sans 3', sans-serif",
        "fontWeight": 600,
        "uppercase": false,
        "sizes": {
          "lg": { "fontSize": 16, "letterSpacing": 0, "opticalYOffset": 0, "paddingTop": 14, "paddingBottom": 14, "paddingLeft": 28, "paddingRight": 28, "borderRadius": 6 },
          "md": { "fontSize": 14, "letterSpacing": 0, "opticalYOffset": 0, "paddingTop": 11, "paddingBottom": 11, "paddingLeft": 22, "paddingRight": 22, "borderRadius": 5 },
          "sm": { "fontSize": 12, "letterSpacing": 0, "opticalYOffset": 0, "paddingTop": 8, "paddingBottom": 8, "paddingLeft": 16, "paddingRight": 16, "borderRadius": 4 }
        }
      },
      "variants": {
        "primary": { "backgroundColor": "system:brand", "textColor": "system:on-brand", "borderColor": "transparent", "borderWidth": 1, "hoverPreset": "scale" },
        "secondary": { "backgroundColor": "system:base-alt", "textColor": "system:fg", "borderColor": "transparent", "borderWidth": 1, "hoverPreset": "darken" },
        "outline": { "backgroundColor": "transparent", "textColor": "system:brand", "borderColor": "system:brand", "borderWidth": 1, "hoverPreset": "fill" },
        "ghost": { "backgroundColor": "transparent", "textColor": "system:fg", "borderColor": "transparent", "borderWidth": 1, "hoverPreset": "darken" }
      }
    }
  },
