    "Features Grid": {
      "Eyebrow": "Services",
      "Headline": "What Allen brings to your project",
      "Subheadline": "<p>A classically trained voice and seasoned performer available for a range of professional engagements.</p>",
      "Features": [
        {
          "icon": "music",
          "headline": "Opera & Concert",
          "description": "<p>Full opera productions, concert series, oratorio, and recital performances. Repertoire from baroque to contemporary.</p>"
        },
        {
          "icon": "microphone",
          "headline": "Voice Over",
          "description": "<p>Commercials, narration, audiobooks, documentaries, and corporate video. Deep, resonant bass-baritone voice.</p>"
        },
        {
          "icon": "star",
          "headline": "Live Event Hosting",
          "description": "<p>Corporate galas, award ceremonies, fundraisers, and special events. Gravitas with warmth.</p>"
        },
        {
          "icon": "graduation-cap",
          "headline": "Vocal Coaching",
          "description": "<p>Private instruction for aspiring singers and public speakers. Technique, breath control, and stage presence.</p>"
        },
        {
          "icon": "headphones",
          "headline": "Studio Recording",
          "description": "<p>Professional home studio with broadcast-quality equipment. Remote recording and directed sessions available.</p>"
        },
        {
          "icon": "calendar",
          "headline": "Custom Engagements",
          "description": "<p>Weddings, memorial services, private performances, and unique occasions that call for a singular voice.</p>"
        }
      ]
    },
    "Content": {
      "Headline": "A voice shaped by the stage",
      "Category": "About",
      "Subheadline": "Classically trained. Professionally versatile.",
      "Content": "<p>Allen Ginsberg is a professionally trained opera singer whose deep, resonant bass-baritone voice has been the foundation of a career spanning more than fifteen years. After earning his Master of Music in Vocal Performance, Allen performed with opera companies and symphony orchestras across the country — building a reputation for vocal power, emotional depth, and an effortless command of the stage.</p><p>That training didn't stay in the concert hall. Today, Allen applies the same discipline and presence to voice over work for major brands, narration for documentaries and audiobooks, and hosting live events where his voice sets the tone for the entire evening. Whether he's performing Verdi or introducing a keynote speaker, Allen delivers with the same conviction and care.</p>",
      "align": "items-start text-left"
    },
    "Testimonials Grid": {
      "Eyebrow": "What Clients Say",
      "Headline": "Trusted by producers, planners, and brands",
      "Subheadline": "<p>Hear from the people who've worked with Allen firsthand.</p>",
      "Testimonials": [
        {
          "quote": "<p>Allen's voice stopped the entire room. We hired him to emcee our annual gala and he elevated the entire evening. Half our guests asked for his card afterward.</p>",
          "name": "Rebecca Thornton",
          "byline": "Director of Events, Lakewood Foundation"
        },
        {
          "quote": "<p>We needed a narrator who could carry a 90-minute documentary without losing the audience. Allen delivered on the first take. His pacing and tone were impeccable.</p>",
          "name": "David Moreira",
          "byline": "Executive Producer, Greyline Films"
        },
        {
          "quote": "<p>Working with Allen on our brand campaign was a revelation. His voice gives our product an authority and warmth that no other talent matched in auditions.</p>",
          "name": "Sarah Kim",
          "byline": "Creative Director, Whitfield Agency"
        }
      ]
    },
    "Form": {
      "headline": "Get in touch",
      "subheadline": "Interested in working with Allen? Fill out the form below and he'll be in touch within 24 hours.",
      "Fields": [
        { "label": "Name", "name": "name", "type": "text" },
        { "label": "Email", "name": "email", "type": "email" },
        { "label": "Tell me about your project", "name": "message", "type": "textarea" }
      ]
    },
