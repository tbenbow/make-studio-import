{
  "fonts": [
    {
      "family": "Instrument Serif",
      "weight": 400,
      "style": "normal"
    },
    {
      "family": "Instrument Serif",
      "weight": 400,
      "style": "italic"
    },
    {
      "family": "Geist",
      "weight": 400,
      "style": "normal"
    },
    {
      "family": "Geist",
      "weight": 500,
      "style": "normal"
    },
    {
      "family": "Geist",
      "weight": 600,
      "style": "normal"
    }
  ],
  "systemColors": {
    "brand": "#C74B16",
    "on-brand": "#FFFFFF",
    "base": "#FAF8F5",
    "base-muted": "#F2EDE7",
    "base-alt": "#E8E0D6",
    "panel": "#FFFFFF",
    "fg": "#1A1613",
    "fg-muted": "#6B6259",
    "fg-alt": "#9B9189",
    "border": "#DDD5CA"
  },
  "customColors": [
    {
      "id": "accent-001",
      "name": "accent",
      "value": "#2563EB"
    }
  ],
  "palette": {
    "primary": {
      "label": "primary",
      "colors": [
        "#F5A57A",
        "#E07A45",
        "#C74B16",
        "#9E3B11",
        "#752C0D"
      ]
    },
    "grays": {
      "label": "gray",
      "colors": [
        "#F2EDE7",
        "#DDD5CA",
        "#9B9189",
        "#6B6259",
        "#1A1613"
      ]
    },
    "accent1": {
      "label": "accent-1",
      "colors": [
        "#93B8F7",
        "#5B94F2",
        "#2563EB",
        "#1D4FC0",
        "#153B90"
      ]
    }
  },
  "headingTypography": {
    "heading-xl": {
      "fontFamily": "Instrument Serif",
      "fontWeight": 400,
      "fontSize": 80,
      "lineHeight": 76,
      "letterSpacing": -1,
      "mobileFontSize": 48,
      "mobileLineHeight": 46
    },
    "heading-lg": {
      "fontFamily": "Instrument Serif",
      "fontWeight": 400,
      "fontSize": 56,
      "lineHeight": 54,
      "letterSpacing": -0.5,
      "mobileFontSize": 36,
      "mobileLineHeight": 34
    },
    "heading-md": {
      "fontFamily": "Instrument Serif",
      "fontWeight": 400,
      "fontSize": 36,
      "lineHeight": 40,
      "letterSpacing": 0,
      "mobileFontSize": 28,
      "mobileLineHeight": 32
    },
    "heading-sm": {
      "fontFamily": "Geist",
      "fontWeight": 500,
      "fontSize": 20,
      "lineHeight": 28,
      "letterSpacing": 0,
      "mobileFontSize": 18,
      "mobileLineHeight": 24
    },
    "heading-xs": {
      "fontFamily": "Geist",
      "fontWeight": 500,
      "fontSize": 16,
      "lineHeight": 24,
      "letterSpacing": 0,
      "mobileFontSize": 14,
      "mobileLineHeight": 20
    }
  },
  "bodyTypography": {
    "body-lg": {
      "fontFamily": "Geist",
      "fontWeight": 400,
      "fontSize": 18,
      "lineHeight": 28,
      "letterSpacing": 0
    },
    "body-md": {
      "fontFamily": "Geist",
      "fontWeight": 400,
      "fontSize": 16,
      "lineHeight": 26,
      "letterSpacing": 0
    },
    "body-sm": {
      "fontFamily": "Geist",
      "fontWeight": 500,
      "fontSize": 14,
      "lineHeight": 22,
      "letterSpacing": 0
    }
  },
  "prose": {
    "elements": {
      "h1": {
        "typographyClass": "heading-xl",
        "marginBottom": 1.5
      },
      "h2": {
        "typographyClass": "heading-lg",
        "marginBottom": 1.25
      },
      "h3": {
        "typographyClass": "heading-md",
        "marginBottom": 1
      },
      "h4": {
        "typographyClass": "heading-sm",
        "marginBottom": 0.75
      },
      "h5": {
        "typographyClass": "heading-xs",
        "marginBottom": 0.5
      },
      "h6": {
        "typographyClass": "heading-xs",
        "marginBottom": 0.5
      },
      "p": {
        "typographyClass": "body-md",
        "marginBottom": 1.25
      },
      "ul": {
        "typographyClass": "body-md",
        "marginBottom": 1.25
      },
      "ol": {
        "typographyClass": "body-md",
        "marginBottom": 1.25
      }
    },
    "lists": {
      "listStyleType": "disc",
      "indent": 1.5,
      "itemSpacing": 0.5,
      "nestedIndent": 1.5
    },
    "links": {
      "color": "brand",
      "hoverColor": "accent",
      "underline": "always"
    }
  },
  "buttons": {
    "global": {
      "fontFamily": "Geist",
      "fontWeight": 600,
      "uppercase": false,
      "sizes": {
        "lg": {
          "fontSize": 16,
          "letterSpacing": 0,
          "opticalYOffset": 0,
          "paddingTop": 14,
          "paddingBottom": 14,
          "paddingLeft": 28,
          "paddingRight": 28,
          "borderRadius": 6
        },
        "md": {
          "fontSize": 14,
          "letterSpacing": 0,
          "opticalYOffset": 0,
          "paddingTop": 8,
          "paddingBottom": 8,
          "paddingLeft": 16,
          "paddingRight": 16,
          "borderRadius": 6
        },
        "sm": {
          "fontSize": 13,
          "letterSpacing": 0,
          "opticalYOffset": 0,
          "paddingTop": 5,
          "paddingBottom": 5,
          "paddingLeft": 14,
          "paddingRight": 14,
          "borderRadius": 6
        }
      }
    },
    "variants": {
      "primary": {
        "backgroundColor": "system:brand",
        "textColor": "system:on-brand",
        "borderColor": "transparent",
        "borderWidth": 0,
        "hoverPreset": "darken"
      },
      "secondary": {
        "backgroundColor": "system:base-muted",
        "textColor": "system:fg",
        "borderColor": "transparent",
        "borderWidth": 0,
        "hoverPreset": "darken"
      },
      "outline": {
        "backgroundColor": "transparent",
        "textColor": "system:fg",
        "borderColor": "system:border",
        "borderWidth": 1,
        "hoverPreset": "fill"
      },
      "ghost": {
        "backgroundColor": "transparent",
        "textColor": "system:fg-muted",
        "borderColor": "transparent",
        "borderWidth": 0,
        "hoverPreset": "lighten"
      }
    }
  }
}
