{
  "fonts": [
    { "family": "Cormorant Garamond", "weight": 300, "style": "normal" },
    { "family": "Cormorant Garamond", "weight": 300, "style": "italic" },
    { "family": "Cormorant Garamond", "weight": 400, "style": "normal" },
    { "family": "Cormorant Garamond", "weight": 400, "style": "italic" },
    { "family": "Cormorant Garamond", "weight": 500, "style": "normal" },
    { "family": "Cormorant Garamond", "weight": 600, "style": "normal" },
    { "family": "Jost", "weight": 300, "style": "normal" },
    { "family": "Jost", "weight": 400, "style": "normal" },
    { "family": "Jost", "weight": 500, "style": "normal" }
  ],
  "systemColors": {
    "base": "#F5F0E8",
    "base-muted": "#DDD5CA",
    "base-alt": "#3E2C1E",
    "panel": "#FAF8F3",
    "fg": "#3E2C1E",
    "fg-muted": "#6B4F3A",
    "fg-alt": "#A8876A",
    "brand": "#7CA5B8",
    "on-brand": "#F5F0E8",
    "border": "#C4B8A8"
  },
  "customColors": [
    { "id": "moss", "name": "moss", "value": "#6B7F5E" },
    { "id": "water-light", "name": "water-light", "value": "#B8D4E3" },
    { "id": "water-pale", "name": "water-pale", "value": "#D6E8F0" }
  ],
  "palette": {
    "primary": {
      "label": "water",
      "colors": ["#D6E8F0", "#B8D4E3", "#7CA5B8", "#5A8A9E", "#3D6F84"]
    },
    "grays": {
      "label": "earth",
      "colors": ["#FAF8F3", "#F5F0E8", "#C4B8A8", "#6B4F3A", "#3E2C1E"]
    }
  },
  "headingTypography": {
    "heading-xl": {
      "fontFamily": "Cormorant Garamond",
      "fontWeight": 300,
      "fontSize": 80,
      "lineHeight": 80,
      "letterSpacing": -0.5,
      "mobileFontSize": 56,
      "mobileLineHeight": 56
    },
    "heading-lg": {
      "fontFamily": "Cormorant Garamond",
      "fontWeight": 300,
      "fontSize": 52,
      "lineHeight": 60,
      "letterSpacing": -0.3,
      "mobileFontSize": 36,
      "mobileLineHeight": 42
    },
    "heading-md": {
      "fontFamily": "Cormorant Garamond",
      "fontWeight": 400,
      "fontSize": 22,
      "lineHeight": 30,
      "letterSpacing": 0,
      "mobileFontSize": 20,
      "mobileLineHeight": 26
    },
    "heading-sm": {
      "fontFamily": "Cormorant Garamond",
      "fontWeight": 400,
      "fontSize": 18,
      "lineHeight": 24,
      "letterSpacing": 0,
      "mobileFontSize": 16,
      "mobileLineHeight": 22
    },
    "heading-xs": {
      "fontFamily": "Jost",
      "fontWeight": 500,
      "fontSize": 11,
      "lineHeight": 16,
      "letterSpacing": 3.5,
      "mobileFontSize": 10,
      "mobileLineHeight": 14
    }
  },
  "bodyTypography": {
    "body-lg": {
      "fontFamily": "Cormorant Garamond",
      "fontWeight": 400,
      "fontStyle": "italic",
      "fontSize": 19,
      "lineHeight": 30,
      "letterSpacing": 0
    },
    "body-md": {
      "fontFamily": "Jost",
      "fontWeight": 300,
      "fontSize": 16,
      "lineHeight": 28,
      "letterSpacing": 0
    },
    "body-sm": {
      "fontFamily": "Jost",
      "fontWeight": 400,
      "fontSize": 13,
      "lineHeight": 20,
      "letterSpacing": 2
    }
  },
  "prose": {
    "elements": {
      "h1": { "typographyClass": "heading-xl", "marginBottom": 1.5 },
      "h2": { "typographyClass": "heading-lg", "marginBottom": 1.25 },
      "h3": { "typographyClass": "heading-md", "marginBottom": 1 },
      "p": { "typographyClass": "body-md", "marginBottom": 1.25 },
      "li": { "typographyClass": "body-md" }
    },
    "lists": { "listStyleType": "disc", "indent": 1.5, "itemSpacing": 0.5 },
    "links": { "color": "brand", "hoverColor": "fg", "underline": "always" }
  },
  "buttons": {
    "global": {
      "fontFamily": "Jost",
      "fontWeight": 400,
      "uppercase": true,
      "sizes": {
        "lg": {
          "fontSize": 14,
          "letterSpacing": 2.5,
          "opticalYOffset": 0,
          "paddingTop": 16,
          "paddingBottom": 16,
          "paddingLeft": 36,
          "paddingRight": 36,
          "borderRadius": 2
        },
        "md": {
          "fontSize": 13,
          "letterSpacing": 2,
          "opticalYOffset": 0,
          "paddingTop": 14,
          "paddingBottom": 14,
          "paddingLeft": 30,
          "paddingRight": 30,
          "borderRadius": 2
        },
        "sm": {
          "fontSize": 12,
          "letterSpacing": 1.5,
          "opticalYOffset": 0,
          "paddingTop": 10,
          "paddingBottom": 10,
          "paddingLeft": 20,
          "paddingRight": 20,
          "borderRadius": 2
        }
      }
    },
    "variants": {
      "primary": {
        "backgroundColor": "system:fg",
        "textColor": "system:base",
        "borderColor": "transparent",
        "borderWidth": 0,
        "hoverPreset": "lighten"
      },
      "secondary": {
        "backgroundColor": "system:panel",
        "textColor": "system:fg",
        "borderColor": "system:border",
        "borderWidth": 1,
        "hoverPreset": "darken"
      },
      "outline": {
        "backgroundColor": "transparent",
        "textColor": "system:brand",
        "borderColor": "system:brand",
        "borderWidth": 1,
        "hoverPreset": "fill"
      },
      "ghost": {
        "backgroundColor": "transparent",
        "textColor": "system:fg-muted",
        "borderColor": "transparent",
        "borderWidth": 0,
        "hoverPreset": "lighten"
      }
    }
  }
}
