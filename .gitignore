node_modules/
.env
.make-studio.json
*.log
**/.DS_Store
backup-*/

# Legacy guides (superseded by docs/capabilities/)
guides-legacy/

# Snapshots are runtime state, not source
themes/*/snapshots/

# Source files are scraped reference material (HTML, screenshots, content dumps)
themes/*/source/

# Iteration artifacts (screenshots from visual iteration loop)
themes/*/iterations/

# Local page previews (generated by render-page.ts)
themes/*/preview/

# Screenshots (reference captures, preview iterations — large binary files)
themes/*/screenshots/

# Experiment outputs
output/

# Sync state is local (tracks last sync timestamp per theme)
themes/*/.sync-state.json

# Workflow progress state (local/ephemeral)
.state/

# Batch conversion state (runtime artifacts)
.batch-state/

# One-off / throwaway scripts (underscore-prefixed or archived)
scripts/_*.ts
scripts/archive/

# Audit artifacts
_block-audit.json

# Factory runtime state
factory/

# Backup themes
themes/tailwind-backup/

# Block catalog working artifacts (screenshots, raw API dumps)
data/catalog/

# Generated mesh gradient experiments
themes/block-ingress/converted/blocks/HeroMeshGen_*
themes/block-ingress/converted/blocks/HeroMesh[A-Z]*
